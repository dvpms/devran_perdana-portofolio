// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

enum Locale {
  id
  en
}

enum CredentialType {
  Sertifikasi
  Pelatihan
}

enum TechStackIcon {
  server
  code
  cloud
  database
  layers
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String?
  passwordHash String
  role         Role     @default(user)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Profile {
  id         String      @id @default(cuid())
  locale     Locale
  name       String
  role       String
  title      String
  email      String
  phone      String
  location   String
  portrait   String
  heading    String
  subheading String
  tagline    String
  focus      String?
  socials    SocialLink[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([locale])
}

model SocialLink {
  id        String   @id @default(cuid())
  profileId String
  label     String
  href      String
  order     Int      @default(0)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model AboutContent {
  id         String   @id @default(cuid())
  locale     Locale
  title      String
  paragraphs String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  techStack  TechStackCategory[]

  @@unique([locale])
}

model TechStackCategory {
  id             String        @id @default(cuid())
  aboutContentId String
  title          String
  icon           TechStackIcon
  items          String[]
  order          Int           @default(0)
  aboutContent   AboutContent  @relation(fields: [aboutContentId], references: [id], onDelete: Cascade)
}

model ResumeContent {
  id          String   @id @default(cuid())
  locale      Locale
  title       String
  description String
  pdfUrl      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([locale])
}

model Project {
  id        String               @id @default(cuid())
  slug      String               @unique
  imageUrl  String
  demoUrl   String?
  role      String?
  tech      String[]
  published Boolean              @default(true)
  sortOrder Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  translations ProjectTranslation[]
}

model ProjectTranslation {
  id            String   @id @default(cuid())
  projectId     String
  locale        Locale
  title         String
  category      String
  intro         String
  context       String
  solution      String
  impact        String?
  contributions String[]
  highlights    String[]
  challenges    String[]
  impacts       Json?

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
}

model Credential {
  id        String                @id @default(cuid())
  slug      String                @unique
  type      CredentialType
  issuer    String
  year      String
  imageUrl  String
  published Boolean               @default(true)
  sortOrder Int                   @default(0)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  translations CredentialTranslation[]
}

model CredentialTranslation {
  id           String     @id @default(cuid())
  credentialId String
  locale       Locale
  title        String
  description  String
  skills       String[]

  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@unique([credentialId, locale])
}
